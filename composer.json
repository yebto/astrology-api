{
    "name": "yebto/astrology-api",
    "description": "PHP SDK for the YEB Astrology API. Natal charts, planetary positions, transits, synastry and moon data.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "yeb",
        "api",
        "sdk",
        "laravel",
        "php",
        "astrology",
        "natal-chart",
        "transit",
        "synastry",
        "moon"
    ],
    "homepage": "https://yeb.to",
    "support": {
        "email": "support@yeb.to",
        "issues": "https://github.com/yebto/astrology-api/issues",
        "source": "https://github.com/yebto/astrology-api"
    },
    "authors": [
        {
            "name": "NETOX Ltd.",
            "email": "support@yeb.to",
            "homepage": "https://yeb.to",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "yebto/api-client": "^1.0"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel Facade & ServiceProvider integration (^10.0|^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "Yebto\\AstrologyAPI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yebto\\AstrologyAPI\\AstrologyAPIServiceProvider"
            ],
            "aliases": {
                "AstrologyAPI": "Yebto\\AstrologyAPI\\Facades\\AstrologyAPI"
            }
        }
    }
}
